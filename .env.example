# Server
PORT=3000
NODE_ENV=development

# Security — generate with: openssl rand -hex 32
JWT_SECRET=change-me

# Supabase PostgreSQL
DATABASE_URL=postgres://user:pass@host:5432/db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Resend Email (optional — emails are silently skipped when not set)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Dev bypass (optional)
DEV_TOKEN=devtoken123

# OpenRouteService (optional — for checkpoint city suggestions along route)
# Free tier: 2,000 requests/day. Sign up at https://openrouteservice.org
ORS_API_KEY=